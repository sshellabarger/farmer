# Database
DATABASE_URL=postgresql://farmlink:farmlink@localhost:5432/farmlink

# Redis
REDIS_URL=redis://localhost:6379

# SMS Provider: telnyx | voipms | whatsapp
SMS_PROVIDER=telnyx

# Telnyx
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+15555555555
TELNYX_MESSAGING_PROFILE_ID=optional_messaging_profile_id

# WhatsApp Cloud API (Meta direct)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=a_secret_string_you_choose
META_APP_SECRET=your_meta_app_secret

# Anthropic
ANTHROPIC_API_KEY=your_api_key

# App
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change_me_in_production
