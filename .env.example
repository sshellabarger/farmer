# Firebase (auto-set in Cloud Functions; needed for local dev with emulator)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GCLOUD_PROJECT=arkansaslocalfoodnetwork

# SMS Provider: telnyx | voipms | whatsapp
SMS_PROVIDER=telnyx

# Telnyx
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+15555555555
TELNYX_MESSAGING_PROFILE_ID=optional_messaging_profile_id
# Public key from Telnyx portal (Account Settings > Public Key) — verifies
# inbound webhook signatures. Required in production (unsigned webhooks are
# rejected); optional in development.
TELNYX_PUBLIC_KEY=your_telnyx_base64_public_key

# voip.ms
VOIPMS_USERNAME=your_voipms_username
VOIPMS_PASSWORD=your_voipms_api_password
VOIPMS_DID=5555555555
# Shared secret guarding the SMS callback (voip.ms can't sign callbacks).
# Set the portal callback URL to .../api/sms/voipms/inbound?secret=<value>
# FIRST, then set this var — order matters or inbound texts get rejected.
VOIPMS_WEBHOOK_SECRET=a_long_random_string_you_choose

# WhatsApp Cloud API (Meta direct)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=a_secret_string_you_choose
META_APP_SECRET=your_meta_app_secret

# Email (Resend)
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=farmlink@yourdomain.com

# App URL (used for web links sent via SMS)
APP_URL=https://arkansaslocalfoodnetwork.web.app

# Anthropic
ANTHROPIC_API_KEY=your_api_key

# App
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change_me_in_production

# Cloud Tasks (for delayed notifications in production)
CLOUD_TASKS_QUEUE=notifications
CLOUD_TASKS_LOCATION=us-central1
# CLOUD_FUNCTIONS_URL=https://us-central1-arkansaslocalfoodnetwork.cloudfunctions.net

# Error alerts — where to text/email errors (with AI-researched fix). Blank disables a channel.
ALERT_EMAIL=you@yourdomain.com
ALERT_PHONE=+15555555555
