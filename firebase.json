{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules",
        "web",
        ".git",
        "uploads"
      ]
    }
  ],
  "hosting": {
    "source": "web",
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "512MiB"
    },
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
