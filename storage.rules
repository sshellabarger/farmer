rules_version = '2';

// All uploads go through the Cloud Function (Admin SDK), which bypasses these
// rules. Images are served via tokenized download URLs. Clients never read/write
// Storage directly, so deny all direct access.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
